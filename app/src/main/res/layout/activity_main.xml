<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <TextView
        android:id="@+id/etTextOsnova"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Калькулятор чаевых"
        android:textSize="20dp"
        android:layout_marginTop="60px"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etBillAmount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Введите сумму счета"
        android:inputType="numberDecimal"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toBottomOf="@id/etTextOsnova"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etTipPercent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Процент чаевых (5-30)"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@+id/etBillAmount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8px" />

    <EditText
        android:id="@+id/etPeopleCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Количество человек"
        android:inputType="number"
        app:layout_constraintTop_toBottomOf="@+id/etTipPercent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8px" />

    <TextView
        android:id="@+id/tvRounding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Способ округления"
        android:textSize="18dp"
        app:layout_constraintTop_toBottomOf="@+id/etPeopleCount"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="20dp" />

    <RadioGroup
        android:id="@+id/rgRounding"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tvRounding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4px">

        <RadioButton
            android:id="@+id/rbDown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="В меньшую" />

        <RadioButton
            android:id="@+id/rbUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="В большую" />

        <RadioButton
            android:id="@+id/rbNearest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="До целого"
            android:checked="true" />
    </RadioGroup>

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Рассчитать"
        app:layout_constraintTop_toBottomOf="@+id/rgRounding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>

    <TextView
        android:id="@+id/tvTipAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сумма чаевых:"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/btnCalculate"
        android:layout_marginTop="28dp" />

    <TextView
        android:id="@+id/tvTotalAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Общая сумма:"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tvTipAmount"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvPerPerson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="На каждого:"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tvTotalAmount"
        android:layout_marginTop="8dp" />


</androidx.constraintlayout.widget.ConstraintLayout>